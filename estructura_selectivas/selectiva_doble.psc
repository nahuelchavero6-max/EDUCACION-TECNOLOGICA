Proceso Selectiva_simple
	//determinar si un nimero es PAR o IMPAR
	definir numero1 como entero;
	escribir"ingrese un numero: ";
	leer numero1;
	//selectiva doble
	Si numero1 MOD 2 = 0 Entonces 
		escribir"Es un numero par ", numero1;
	sino 
		escribir"es un numero IMPAR",numero1;
	FinSi
FinProceso
